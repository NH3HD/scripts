local EasingFunctions = {
    ["Constant"] = function(t) return 1.0 end,
    ["Linear"] = function(t) return t end,
    ["In Quad"] = function(t) return t * t end,
    ["Out Quad"] = function(t) return 1 - (1 - t) * (1 - t) end,
    ["InOut Quad"] = function(t) return t < 0.5 and 2 * t * t or 1 - ((-2 * t + 2)^2) / 2 end,
    ["In Cubic"] = function(t) return t^3 end,
    ["Out Cubic"] = function(t) return 1 - (1 - t)^3 end,
    ["InOut Cubic"] = function(t) return t < 0.5 and 4 * t^3 or 1 - (-2 * t + 2)^3 / 2 end,
    ["In Quart"] = function(t) return t^4 end,
    ["Out Quart"] = function(t) return 1 - (1 - t)^4 end,
    ["InOut Quart"] = function(t) return t < 0.5 and 8 * t^4 or 1 - (-2 * t + 2)^4 / 2 end,
    ["In Quint"] = function(t) return t^5 end,
    ["Out Quint"] = function(t) return 1 - (1 - t)^5 end,
    ["InOut Quint"] = function(t) return t < 0.5 and 16 * t^5 or 1 - (-2 * t + 2)^5 / 2 end,
    ["Sine In"] = function(t) return 1 - math.cos((t * math.pi) / 2) end,
    ["Sine Out"] = function(t) return math.sin((t * math.pi) / 2) end,
    ["Sine InOut"] = function(t) return -(math.cos(math.pi * t) - 1) / 2 end,
    ["In Expo"] = function(t) return t == 0 and 0 or 2^(10 * t - 10) end,
    ["Out Expo"] = function(t) return t == 1 and 1 or 1 - 2^(-10 * t) end,
    ["InOut Expo"] = function(t) return t == 0 and 0 or (t == 1 and 1 or (t < 0.5 and 2^(20 * t - 10) / 2 or (2 - 2^(-20 * t + 10)) / 2)) end,
    ["In Circ"] = function(t) return 1 - math.sqrt(1 - t^2) end,
    ["Out Circ"] = function(t) return math.sqrt(1 - (t - 1)^2) end,
    ["InOut Circ"] = function(t) return t < 0.5 and (1 - math.sqrt(1 - (2 * t)^2)) / 2 or (math.sqrt(1 - (-2 * t + 2)^2) + 1) / 2 end,
    ["In Back"] = function(t) local c1 = 1.70158; local c3 = c1 + 1; return c3 * t^3 - c1 * t^2 end,
    ["Out Back"] = function(t) local c1 = 1.70158; local c3 = c1 + 1; return 1 + c3 * (t - 1)^3 + c1 * (t - 1)^2 end,
    ["InOut Back"] = function(t) local c1 = 1.70158; local c2 = c1 * 1.525; return t < 0.5 and ((2 * t)^2 * ((c2 + 1) * 2 * t - c2)) / 2 or ((2 * t - 2)^2 * ((c2 + 1) * (t * 2 - 2) + c2) + 2) / 2 end
}

local EasingNames = {
    "Constant", "Linear", 
    "In Quad", "Out Quad", "InOut Quad", 
    "In Cubic", "Out Cubic", "InOut Cubic",
    "In Quart", "Out Quart", "InOut Quart",
    "In Quint", "Out Quint", "InOut Quint",
    "Sine In", "Sine Out", "Sine InOut",
    "In Expo", "Out Expo", "InOut Expo",
    "In Circ", "Out Circ", "InOut Circ",
    "In Back", "Out Back", "InOut Back"
}
local SecondaryEasingNames = {"None"}
for i, v in ipairs(EasingNames) do table.insert(SecondaryEasingNames, v) end

local function GetBlendedEasing(t, easeIdx1, easeIdx2)
    local e1Name = EasingNames[easeIdx1 + 1] or "Constant"
    local func1 = EasingFunctions[e1Name]
    
    if not easeIdx2 or easeIdx2 == 0 then
        return func1(t)
    end
    
    local e2Name = SecondaryEasingNames[easeIdx2 + 1] or "Constant"
    local func2 = EasingFunctions[e2Name]
    
    if t < 0.5 then
        return func1(t * 2) * 0.5
    else
        return 0.5 + (func2((t - 0.5) * 2) * 0.5)
    end
end

