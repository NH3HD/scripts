local function GetCurrentOperationOneWeapon()
    if game.PlaceID ~= OPERATION_ONE_PLACE_ID then return nil, nil, nil end
    local viewmodels = game.Workspace:FindFirstChild("Viewmodels")
    local localViewmodel = viewmodels and viewmodels:FindFirstChild("LocalViewmodel")
    
    if localViewmodel then
        local children = localViewmodel:GetChildren()
        for i = 1, #children do
            local item = children[i]
            if item.ClassName == "Model" then
                local keyAttr = item:GetAttribute("key")
                if keyAttr and type(keyAttr.Value) == "string" then
                    if keyAttr.Value == "primary" or keyAttr.Value == "secondary" then
                        return item, item.Name, keyAttr.Value 
                    end
                end
            end
        end
    end
    return nil, nil, nil
end

local function ScanAmmoLabels()
    local currentTick = utility.GetTickCount()
    if currentTick - lastScanTime < 1000 then return end 
    lastScanTime = currentTick

    local lp = game.LocalPlayer
    if not lp then return end
    
    local pGui = lp:FindFirstChild("PlayerGui")
    if not pGui then return end
    
    local gameGui = pGui:FindFirstChild("Game")
    local right = gameGui and gameGui:FindFirstChild("Right")
    local bottom = right and right:FindFirstChild("Bottom")
    local backpack = bottom and bottom:FindFirstChild("BackpackItems")
    
    if not backpack then return end

    local updatedCache = false
    
    for _, itemFrame in ipairs(backpack:GetChildren()) do
        if itemFrame.Name == "Item" then
            
            local folder = itemFrame:FindFirstChild("Folder")
            local actionsList = folder and folder:FindFirstChild("ActionsList")
            local key = actionsList and actionsList:FindFirstChild("Key")
            
            local isWeaponSlot = nil
            
            if key then
                if key:FindFirstChild("Enum.KeyCode.One") then
                    isWeaponSlot = "primary"
                elseif key:FindFirstChild("Enum.KeyCode.Two") then
                    isWeaponSlot = "secondary"
                end
            end
            
            if isWeaponSlot then
                local itemObjVal = itemFrame:FindFirstChild("Item")
                local infoLabel = itemFrame:FindFirstChild("InfoLabel")
                
                if itemObjVal and infoLabel then
                    local wInst = itemObjVal.Value
                    if wInst and wInst.Name then
                        local wName = wInst.Name
                        
                        AmmoInstancesCache[wName] = infoLabel 
                        AmmoInstancesCache[isWeaponSlot] = infoLabel 
                        
                        local addrStr = tostring(infoLabel.Address or "0")
                        if MasterSettings.AmmoCache[wName] ~= addrStr then
                            MasterSettings.AmmoCache[wName] = addrStr
                            updatedCache = true
                        end
                    end
                end
            end
        end
    end
    
    if updatedCache then SaveMasterSettings() end
end

local function GetWeaponAmmo(weaponName, slotName)
    local label = AmmoInstancesCache[weaponName] or AmmoInstancesCache[slotName]
    if not label then return true, "N/A" end 
    
    local success, text = pcall(function() return label.Text end)
    if not success or type(text) ~= "string" then
        success, text = pcall(function() return label.Value end)
    end
    
    if success and type(text) == "string" then
        local currentAmmoStr = string.match(text, "^%s*(%d+)%s*/")
        if currentAmmoStr then
            local currentAmmo = tonumber(currentAmmoStr)
            return (currentAmmo > 0), text
        end
    end
    return true, "Err"
end

-- Dynamically finds and caches the nearest WarehouseMenu
local function UpdatePVECache(forceUpdate)
    local currentTick = utility.GetTickCount()
    -- Only scan Workspace every 2000ms (2 seconds) to preserve FPS, unless forced
    if not forceUpdate and (currentTick - PVE_CACHE.LastUpdate < 2000) then return end
    PVE_CACHE.LastUpdate = currentTick

    local lp = game.LocalPlayer
    local char = lp and lp.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local myPos = root.Position
    local closestMenu = nil
    local closestDist = math.huge

    -- Scan Workspace for all WarehouseMenu models to find the closest one
    local workspaceChildren = game.Workspace:GetChildren()
    for i = 1, #workspaceChildren do
        local child = workspaceChildren[i]
        if child.Name == "WarehouseMenu" and child.ClassName == "Model" then
            
            -- Find a reference part inside the warehouse to calculate distance
            local refPart = child:FindFirstChildOfClass("UnionOperation") or child:FindFirstChildOfClass("BasePart")
            if not refPart then
                local firstTarget = child:FindFirstChild("Target")
                if firstTarget then
                    refPart = firstTarget:FindFirstChildOfClass("UnionOperation") or firstTarget:FindFirstChildOfClass("BasePart")
                end
            end

            if refPart then
                local rPos = refPart.Position
                local dist = math.sqrt((rPos.X - myPos.X)^2 + (rPos.Y - myPos.Y)^2 + (rPos.Z - myPos.Z)^2)
                if dist < closestDist then
                    closestDist = dist
                    closestMenu = child
                end
            end
        end
    end

    -- Only cache if we are relatively close to the warehouse
    if closestMenu and closestDist < 500 then
        PVE_CACHE.ClosestMenu = closestMenu
    else
        PVE_CACHE.ClosestMenu = nil
    end
end

