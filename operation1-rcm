-- Calculates distance from screen center to the closest edge of a bounding box
local function GetDistanceToBox(cx, cy, x, y, w, h)
    local closestX = math.max(x, math.min(cx, x + w))
    local closestY = math.max(y, math.min(cy, y + h))
    return math.sqrt((closestX - cx)^2 + (closestY - cy)^2)
end

-- Checks both real players and dynamic PVE Targets precisely inside the FOV
local function GetTargetInFOV(radius)
    local w, h = ScreenSize.w, ScreenSize.h
    if w == 0 then updateScreenSize(); w = ScreenSize.w; h = ScreenSize.h end
    local cx, cy = w/2, h/2
    
    local closestDist = radius
    local bestTargetName = nil
    local found = false
    
    -- 1. Check PvP Real Players (Using Bounding Box edges instead of center for low FOV accuracy)
    local players = entity.GetPlayers()
    if players then
        for _, player in ipairs(players) do
            if player.IsAlive and (player.Health > 0) and player.IsVisible and player.IsEnemy then
                local bbox = player.BoundingBox
                if bbox then
                    local dist = GetDistanceToBox(cx, cy, bbox.x, bbox.y, bbox.w, bbox.h)
                    if dist <= closestDist then
                        closestDist = dist
                        bestTargetName = player.Name
                        found = true
                    end
                end
            end
        end
    end

    -- 2. Check PVE Warehouse Targets
    -- Validate if the cached menu still exists
    if PVE_CACHE.ClosestMenu then
        local success, parent = pcall(function() return PVE_CACHE.ClosestMenu.Parent end)
        if not success or parent == nil then
            PVE_CACHE.ClosestMenu = nil
            UpdatePVECache(true) -- Force update immediately
        end
    end

    -- Dynamically iterate targets and project 3D bounds to 2D screen box
    if PVE_CACHE.ClosestMenu then
        local menuChildren = PVE_CACHE.ClosestMenu:GetChildren()
        for i = 1, #menuChildren do
            local item = menuChildren[i]
            if item.Name == "Target" and item.ClassName == "Model" then
                local tPart = item:FindFirstChildOfClass("UnionOperation") or item:FindFirstChildOfClass("BasePart")
                if tPart then
                    local corners = draw.GetPartCorners(tPart)
                    if corners then
                        local minX, minY = math.huge, math.huge
                        local maxX, maxY = -math.huge, -math.huge
                        local validCorners = 0
                        
                        for _, corner3D in ipairs(corners) do
                            local sx, sy, onScreen = utility.WorldToScreen(corner3D)
                            if onScreen then
                                if sx < minX then minX = sx end
                                if sy < minY then minY = sy end
                                if sx > maxX then maxX = sx end
                                if sy > maxY then maxY = sy end
                                validCorners = validCorners + 1
                            end
                        end
                        
                        if validCorners > 0 then
                            local boxW, boxH = maxX - minX, maxY - minY
                            local dist = GetDistanceToBox(cx, cy, minX, minY, boxW, boxH)
                            if dist <= closestDist then
                                closestDist = dist
                                bestTargetName = "Warehouse Target"
                                found = true
                            end
                        end
                    end
                end
            end
        end
    end

    return found, bestTargetName
end

