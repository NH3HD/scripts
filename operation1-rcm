                local name = ConfigNames[currentDropdownIdx + 1]
                if name and name ~= "None" then
                    ui.setValue(kUiTab, kUiMisc, "Config Name", name)
                    LoadConfigData(name)
                    DebugPrint("[OpOne] Loaded config via UI: " .. name)
                end
            end
        end
        return 
    end

    if game.PlaceID == OPERATION_ONE_PLACE_ID then
        if not hasDetectedGame then
            hasDetectedGame = true
        end
        
        ScanAmmoLabels() 
        
        local currentOpOneWeaponInstance, currentOpOneWeapon, currentSlot = GetCurrentOperationOneWeapon()
        if currentOpOneWeapon ~= lastDetectedWeapon then
            lastDetectedWeaponInstance = currentOpOneWeaponInstance
            lastDetectedWeapon = currentOpOneWeapon
            lastDetectedSlot = currentSlot
            
            if currentOpOneWeapon and WeaponLinks[currentOpOneWeapon] then
                LoadConfigData(WeaponLinks[currentOpOneWeapon])
                DebugPrint("[OpOne] Loaded config '" .. WeaponLinks[currentOpOneWeapon] .. "' by linked weapon: " .. currentOpOneWeapon)
            else
                if MasterSettings.UseDefaultConfig then
                    local defConfig = MasterSettings.DefaultConfigName
                    if defConfig and AllConfigs[defConfig] then
                        LoadConfigData(defConfig)
                        DebugPrint("[OpOne] Fallback loaded config: " .. defConfig)
                    end
                end
            end
        else
            lastDetectedWeaponInstance = currentOpOneWeaponInstance
        end
    end

    if not (ui.getValue(kUiTab, kUiMisc, "Enable Recoil Macro") or false) then 
        isFiring = false; return 
    end

    local finalActive = false
    
    local k1_idx = ui.getValue(kUiTab, kUiMain, "Trigger Key 1")
    local k2_idx = ui.getValue(kUiTab, kUiMain, "Trigger Key 2")
    local logic_idx = ui.getValue(kUiTab, kUiMain, "Combo Logic") 
    local mode_idx = ui.getValue(kUiTab, kUiMain, "Activation Mode")
    
    local press1 = IsMappedKeyPressed(k1_idx)
    local press2 = IsMappedKeyPressed(k2_idx)
    local inputActive = (k2_idx == 0) and press1 or ((logic_idx == 0) and (press1 or press2) or (press1 and press2))
    
    if mode_idx == 2 then finalActive = true
    elseif mode_idx == 1 then 
        if inputActive and not lastInputState then toggleState = not toggleState end
        finalActive = toggleState
    else finalActive = inputActive end
    lastInputState = inputActive

    if finalActive and ui.getValue(kUiTab, kUiMisc, "Tool Check") then
        local isHoldingValidTool = false

        if game.PlaceID == OPERATION_ONE_PLACE_ID then
            local opOneWpn = GetCurrentOperationOneWeapon()
            isHoldingValidTool = (opOneWpn ~= nil)
        else
            if game.LocalPlayer and game.LocalPlayer.Character then
                isHoldingValidTool = game.LocalPlayer.Character:FindFirstChildOfClass("Tool") ~= nil
            else 
                isHoldingValidTool = true 
            end
        end
        
        DebugState.ToolValid = isHoldingValidTool
        if not isHoldingValidTool then 
            finalActive = false
            isFiring = false 
        end
    end
    
    if finalActive and hasAmmoCheck and not hasAmmo then
        finalActive = false
        isFiring = false
    end
    
    local isTargetCheckEnabled = ui.getValue(kUiTab, kUiMisc, "Target Check (FOV)")
    
    if finalActive and isTargetCheckEnabled then
        local fov = ui.getValue(kUiTab, kUiMisc, "Target FOV") or 100
        local inFOV, targetName = GetTargetInFOV(fov)
        DebugState.TargetFOV = inFOV
        DebugState.CurrentTarget = targetName or "None"
        if not inFOV then
            finalActive = false; isFiring = false
        end
    elseif not isTargetCheckEnabled then
        DebugState.TargetFOV = false
        DebugState.CurrentTarget = "None"
    end
    
    if finalActive then
        if not isFiring then 
            isFiring = true 
            sprayStartTime = utility.GetTickCount()
            moveAccumulatorX = 0
            moveAccumulatorY = 0
            DebugState.TotalX = 0
            DebugState.TotalY = 0
            DebugState.SprayPath = {{x = 0, y = 0}}
        end
        
        local currentTick = utility.GetTickCount()
        local delay = ui.getValue(kUiTab, kUiMain, "Delay (ms)") or 10
        
        if currentTick - lastTick >= delay then
            lastTick = currentTick
            local rX = ui.getValue(kUiTab, kUiMain, "Recoil X") or 0
            local rY = ui.getValue(kUiTab, kUiMain, "Recoil Y") or 0
            local smooth = ui.getValue(kUiTab, kUiMain, "Smoothness") or 1
            local easeIdx1 = ui.getValue(kUiTab, kUiMain, "Primary Easing") or 0
            local easeIdx2 = ui.getValue(kUiTab, kUiMain, "Secondary Easing") or 0
            local easingTime = ui.getValue(kUiTab, kUiMain, "Easing Time (ms)") or 1000
            
            local t = (currentTick - sprayStartTime) / easingTime
            if t > 1.0 then t = 1.0 end
            
            local mult = GetBlendedEasing(t, easeIdx1, easeIdx2)
            local baseFactor = ui.getValue(kUiTab, kUiMain, "Precision Mode (1/10)") and 10 or 1
            
            local stepX = (rX / baseFactor / smooth) * mult
            local stepY = (rY / baseFactor / smooth) * mult
            
            local randPerc = ui.getValue(kUiTab, kUiMain, "Randomizer %") or 0
            if randPerc > 0 then
                local randStr = (randPerc / 100) * 1.5
                stepX = stepX + utility.RandomFloat(-randStr, randStr)
                stepY = stepY + utility.RandomFloat(-randStr, randStr)
            end

            moveAccumulatorX = moveAccumulatorX + stepX
            moveAccumulatorY = moveAccumulatorY + stepY
            DebugState.AccX = moveAccumulatorX
            DebugState.AccY = moveAccumulatorY

            local finalMoveX = math.floor(moveAccumulatorX)
            local finalMoveY = math.floor(moveAccumulatorY)

            if finalMoveX ~= 0 or finalMoveY ~= 0 then
                utility.MoveMouse(finalMoveX, finalMoveY)
                moveAccumulatorX = moveAccumulatorX - finalMoveX
                moveAccumulatorY = moveAccumulatorY - finalMoveY
                
                DebugState.TotalX = DebugState.TotalX + finalMoveX
                DebugState.TotalY = DebugState.TotalY + finalMoveY
                table.insert(DebugState.SprayPath, {x = DebugState.TotalX, y = DebugState.TotalY})
            end
        end
    else 
        isFiring = false 
    end
    
    DebugState.Firing = isFiring
end)
