local function LoadFromFile()
    local content = file.read(FILE_PATH)
    if not content or content == "" then UpdateConfigNames(); return end
    AllConfigs = {}
    local currentData = {}
    local insideBlock = false
    for line in string.gmatch(content, "[^\r\n]+") do
        local clean = string.match(line, "^%s*(.-)%s*$")
        if clean == "{" then insideBlock = true; currentData = {}
        elseif clean == "}" then insideBlock = false; if currentData.config_name then AllConfigs[currentData.config_name] = currentData end
        elseif insideBlock and clean ~= "" then
            local key, val = string.match(clean, '^(.-):%s*"(.-)"')
            if key and val then
                if key == "config_name" then currentData.config_name = val
                elseif val == "true" then currentData[key] = true
                elseif val == "false" then currentData[key] = false
                elseif key == "easing_type" then currentData[key] = val
                elseif key == "easing_type_2" then currentData[key] = val
                elseif key == "ramp_time" or key == "easing_time" then 
                    currentData["easing_time"] = tonumber(val) or 1000 
                else currentData[key] = tonumber(val) or 0 end
            end
        end
    end
    UpdateConfigNames()
end

local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'

local function base64_encode(data)
    return ((data:gsub('.', function(x) 
        local r, b = '', x:byte()
        for i = 8, 1, -1 do r = r .. (math.floor(b % 2^i / 2^(i-1)) > 0 and '1' or '0') end
        return r
    end)..'0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c = 0
        for i = 1, 6 do c = c + (x:sub(i,i) == '1' and 2^(6-i) or 0) end
        return b64chars:sub(c+1, c+1)
    end)..({ '', '==', '=' })[#data%3+1])
end

local function base64_decode(data)
    data = string.gsub(data, '[^'..b64chars..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b64chars:find(x)-1)
        for i = 6, 1, -1 do r = r .. (math.floor(f % 2^i / 2^(i-1)) > 0 and '1' or '0') end
        return r
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c = 0
        for i = 1, 8 do c = c + (x:sub(i,i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local function SerializeConfig(cfgName, cfg)
    local parts = {}
    table.insert(parts, "config_name=" .. tostring(cfgName))
    for k, v in pairs(cfg) do
        table.insert(parts, tostring(k) .. "=" .. tostring(v))
    end
    local rawStr = "[UniversalRC]" .. table.concat(parts, ";")
    return base64_encode(rawStr)
end

local function DeserializeConfig(encodedStr)
    if not encodedStr or type(encodedStr) ~= "string" then return nil end
    
    local success, decodedStr = pcall(base64_decode, encodedStr)
    if not success or not decodedStr or string.sub(decodedStr, 1, 13) ~= "[UniversalRC]" then return nil end
    
    local cfg = {}
    local dataStr = string.sub(decodedStr, 14)
    for k, v in string.gmatch(dataStr, "([^=;]+)=([^=;]+)") do
        if v == "true" then cfg[k] = true
        elseif v == "false" then cfg[k] = false
        elseif tonumber(v) then cfg[k] = tonumber(v)
        else cfg[k] = v end
    end
    
    if cfg.recoil_x == nil or cfg.recoil_y == nil then return nil end
    return cfg
end

