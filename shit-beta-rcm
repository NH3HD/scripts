-- Novo Timeline Graph ao Estilo DaVinci / Premiere
local function DrawTimelineGraph()
    if not IsScriptActive or not utility.GetMenuState() then return end
    local kfCheck = ui.getValue(kUiTabKF, kUiKFMain, "Enable Keyframing")
    local showTimeline = ui.getValue(kUiTabKF, kUiKFMain, "Show Timeline Graph")
    if not kfCheck or not showTimeline then return end

    local gx = tonumber(ui.getValue(kUiTabKF, kUiKFMain, "Graph Pos X")) or 600
    local gy = tonumber(ui.getValue(kUiTabKF, kUiKFMain, "Graph Pos Y")) or 300
    local boxW, boxH = 400, 200
    
    local mousePos = utility.GetMousePos()
    local mx, my = (mousePos and mousePos.x or 0), (mousePos and mousePos.y or 0)
    local isLmbDown = keyboard and keyboard.IsPressed(1)
    
    if isLmbDown then
        if not isDraggingTimeline then
            if mx >= gx and mx <= (gx + boxW) and my >= gy and my <= (gy + boxH) then
                isDraggingTimeline = true; tlDragOffsetX = mx - gx; tlDragOffsetY = my - gy
            end
        else
            local nx, ny = mx - tlDragOffsetX, my - tlDragOffsetY
            pcall(ui.setValue, kUiTabKF, kUiKFMain, "Graph Pos X", nx)
            pcall(ui.setValue, kUiTabKF, kUiKFMain, "Graph Pos Y", ny)
            gx, gy = nx, ny
        end
    else isDraggingTimeline = false end

    if draw then
        draw.RectFilled(gx, gy, boxW, boxH, Color3.new(0.05, 0.05, 0.05), 0, 240)
        draw.Rect(gx, gy, boxW, boxH, isDraggingTimeline and Color3.new(1,1,1) or Color3.new(0, 0.8, 0.5), 1, 0, 255)
        draw.TextOutlined("KEYFRAME TIMELINE (RED=X, GREEN=Y)", gx + 5, gy + 5, Color3.new(1,1,1), "SmallestPixel", 200)

        local activeKFs = ui.getValue(kUiTabKF, kUiKFMain, "Active Keyframes") or 3
        local maxTime = 1
        for i = 1, activeKFs do
            local kt = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Time (ms)") or 0
            if kt > maxTime then maxTime = kt end
        end
        if maxTime < 100 then maxTime = 100 end 
        
        local minVal, maxVal = 0, 0
        local rXBase = ui.getValue(kUiTab, kUiMain, "Recoil X (Base)") or 0
        local rYBase = ui.getValue(kUiTab, kUiMain, "Recoil Y") or 0
        
        local scaleX = (ui.getValue(kUiTabKF, kUiKFMain, "Master Scale X (%)") or 100) / 100.0
        local scaleY = (ui.getValue(kUiTabKF, kUiKFMain, "Master Scale Y (%)") or 100) / 100.0
        
        local function checkBounds(x, y)
            if x < minVal then minVal = x end; if x > maxVal then maxVal = x end
            if y < minVal then minVal = y end; if y > maxVal then maxVal = y end
        end
        checkBounds(rXBase, rYBase)
        
        for i = 1, activeKFs do
            checkBounds((ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil X") or 0)*scaleX, (ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil Y") or 0)*scaleY)
        end
        
        local rangeVal = maxVal - minVal
        if rangeVal == 0 then rangeVal = 1 end
        local zeroY = gy + boxH - ((0 - minVal) / rangeVal) * (boxH - 40) - 20
        
        -- Zero Line (Reference point)
        draw.Line(gx, zeroY, gx + boxW, zeroY, Color3.new(0.3, 0.3, 0.3), 1, 150)
        draw.TextOutlined("0", gx + boxW - 15, zeroY - 5, Color3.new(0.5, 0.5, 0.5), "SmallestPixel", 200)
        
        local prevEx, prevEyX, prevEyY = nil, nil, nil
        local resolution = boxW 
        
        for i = 0, resolution do
            local t = (i / resolution) * maxTime
            local curX, curY = GetCurrentRecoil(t)
            
            local plotX = gx + i
            local plotY_X = gy + boxH - ((curX - minVal) / rangeVal) * (boxH - 40) - 20
            local plotY_Y = gy + boxH - ((curY - minVal) / rangeVal) * (boxH - 40) - 20
            
            if prevEx then
                draw.Line(prevEx, prevEyX, plotX, plotY_X, Color3.new(1, 0.2, 0.2), 2, 255)
                draw.Line(prevEx, prevEyY, plotX, plotY_Y, Color3.new(0.2, 1, 0.2), 2, 255)
            end
            prevEx, prevEyX, prevEyY = plotX, plotY_X, plotY_Y
        end
        
        -- Draw the Keyframe Nodes exactly on the timeline
        local lastT = 0
        for i = 1, activeKFs do
            local kt = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Time (ms)") or 0
            kt = math.max(lastT + 1, kt)
            lastT = kt
            
            local kX = (ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil X") or 0) * scaleX
            local kY = (ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil Y") or 0) * scaleY
            
            local plotX = gx + (kt / maxTime) * boxW
            local plotY_X = gy + boxH - ((kX - minVal) / rangeVal) * (boxH - 40) - 20
            local plotY_Y = gy + boxH - ((kY - minVal) / rangeVal) * (boxH - 40) - 20
            
            draw.CircleFilled(plotX, plotY_X, 3, Color3.new(1, 0.5, 0.5), 8, 255)
            draw.CircleFilled(plotX, plotY_Y, 3, Color3.new(0.5, 1, 0.5), 8, 255)
            
            draw.Line(plotX, gy + 20, plotX, gy + boxH, Color3.new(0.5, 0.5, 0.5), 1, 50)
            draw.TextOutlined("K" .. i, plotX - 6, gy + boxH - 12, Color3.new(1, 1, 1), "SmallestPixel", 200)
        end
    end
end

local function SafeDrawGraph()
    if not IsScriptActive or not utility.GetMenuState() then return end
    local successUI, showGraph = pcall(ui.getValue, kUiTab, kUiMisc, "Show Recoil Graph")
    if not successUI or not showGraph then return end

    local gx = tonumber(ui.getValue(kUiTab, kUiMisc, "Graph Pos X")) or 300
    local gy = tonumber(ui.getValue(kUiTab, kUiMisc, "Graph Pos Y")) or 300
    local boxSize = tonumber(ui.getValue(kUiTab, kUiMisc, "Graph Size")) or 220
    
    local mousePos = utility.GetMousePos()
    local mx, my = (mousePos and mousePos.x or 0), (mousePos and mousePos.y or 0)
    local isLmbDown = keyboard and keyboard.IsPressed(1)
    
    if isLmbDown then
        if not isDraggingGraph then
            if mx >= gx and mx <= (gx + boxSize) and my >= gy and my <= (gy + boxSize) then
                isDraggingGraph = true; dragOffsetX = mx - gx; dragOffsetY = my - gy
            end
        else
            local nx, ny = mx - dragOffsetX, my - dragOffsetY
            pcall(ui.setValue, kUiTab, kUiMisc, "Graph Pos X", nx)
            pcall(ui.setValue, kUiTab, kUiMisc, "Graph Pos Y", ny)
            gx, gy = nx, ny
        end
    else isDraggingGraph = false end

    if draw then
        draw.RectFilled(gx, gy, boxSize, boxSize, Color3.new(0.05, 0.05, 0.05), 0, 240)
        draw.Rect(gx, gy, boxSize, boxSize, isDraggingGraph and Color3.new(1,1,1) or Color3.new(0, 0.8, 0.5), 1, 0, 255)
        draw.TextOutlined("RECOIL SIMULATION", gx + 5, gy + 5, Color3.new(1,1,1), "SmallestPixel", 200)

        local easingTime = ui.getValue(kUiTab, kUiMain, "Easing Time (ms)") or 1000
        local easeIdx1 = ui.getValue(kUiTab, kUiMain, "Primary Easing") or 0
        local easeIdx2 = ui.getValue(kUiTab, kUiMain, "Secondary Easing") or 0
        
        local isWeak = ui.getValue(kUiTab, kUiMain, "Precision Mode (1/10)")
        local randPerc = ui.getValue(kUiTab, kUiMain, "Randomizer %") or 0
        local baseFactor = isWeak and 10 or 1 
        
        local kfCheck = ui.getValue(kUiTabKF, kUiKFMain, "Enable Keyframing")

        local simPoints = {}
        local simX, simY = 0, 0
        table.insert(simPoints, {x = 0, y = 0, speed = 0})
        local maxSpeed = 0
        local minX, maxX, minY, maxY = 0, 0, 0, 0
        
        for t = 0, easingTime, 10 do
            local progress = t / easingTime
            if progress > 1 then progress = 1 end
            
            local mult = 1.0
            if not kfCheck then
                mult = GetBlendedEasing(progress, easeIdx1, easeIdx2)
            end
            
            local curRx, curRy = GetCurrentRecoil(t)
            
            local stepX = (curRx / baseFactor) * mult
            local stepY = (curRy / baseFactor) * mult
            
            if randPerc > 0 then
                local randStr = (randPerc / 100) * 1.5
                stepX = stepX + utility.RandomFloat(-randStr, randStr)
                stepY = stepY + utility.RandomFloat(-randStr, randStr)
            end
            
            local currentSpeed = math.sqrt(stepX^2 + stepY^2)
            if currentSpeed > maxSpeed then maxSpeed = currentSpeed end
            simX = simX + stepX; simY = simY + stepY
            
            if simX < minX then minX = simX end; if simX > maxX then maxX = simX end
            if simY < minY then minY = simY end; if simY > maxY then maxY = simY end
            table.insert(simPoints, {x = simX, y = simY, speed = currentSpeed})
        end

        local rangeX, rangeY = maxX - minX, maxY - minY
        if rangeX == 0 then rangeX = 1 end; if rangeY == 0 then rangeY = 1 end
        local maxDist = math.max(math.abs(minX), math.abs(maxX), math.abs(minY), math.abs(maxY))
        local finalScale = 1.0
        local maxVisible = (boxSize/2) - 20
        if maxDist > maxVisible then finalScale = maxVisible / maxDist end

        local centerX, centerY = gx + (boxSize / 2), gy + (boxSize / 2)
        draw.Line(centerX, gy, centerX, gy+boxSize, Color3.new(0.3,0.3,0.3), 1, 100)
        draw.Line(gx, centerY, gx+boxSize, centerY, Color3.new(0.3,0.3,0.3), 1, 100)

        local cGreen, cYellow, cRed = Color3.new(0,1,0), Color3.new(1,1,0), Color3.new(1,0,0)
        if #simPoints > 1 then
            for i = 1, #simPoints - 1 do
                local p1, p2 = simPoints[i], simPoints[i+1]
                local x1 = centerX + p1.x * finalScale
                local y1 = centerY - p1.y * finalScale 
                local x2 = centerX + p2.x * finalScale
                local y2 = centerY - p2.y * finalScale 
                
                local intensity = (maxSpeed > 0) and (p2.speed / maxSpeed) or 0
                local segColor = (intensity < 0.5) and cGreen:Lerp(cYellow, intensity*2) or cYellow:Lerp(cRed, (intensity-0.5)*2)
                draw.Line(x1, y1, x2, y2, segColor, 2, 255)
            end
        end
        draw.CircleFilled(centerX, centerY, 3, Color3.new(1,1,1), 8, 255)
        
        local showNodes = ui.getValue(kUiTabKF, kUiKFMain, "Visualize Keyframe Nodes")
        if kfCheck and showNodes then
            local activeKFs = ui.getValue(kUiTabKF, kUiKFMain, "Active Keyframes") or 1
            local lastT = 0
            for i = 1, activeKFs do
                local kt = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Time (ms)") or 0
                kt = math.max(lastT + 1, kt)
                lastT = kt
                
                -- Se a simulação chegou no tempo desse KF, desenha-o
                for j = 1, #simPoints do
                    local st = (j / #simPoints) * easingTime
                    if math.abs(st - kt) < (easingTime / #simPoints) then
                        local nx = centerX + simPoints[j].x * finalScale
                        local ny = centerY - simPoints[j].y * finalScale
                        draw.CircleFilled(nx, ny, 4, Color3.new(0, 1, 1), 8, 255)
                        draw.TextOutlined("KF" .. i, nx + 6, ny - 6, Color3.new(0, 1, 1), "SmallestPixel", 255)
                        break
                    end
                end
            end
        end
    end
end

