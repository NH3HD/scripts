local function DrawActiveRecoilLine()
    if not IsScriptActive then return end
    if not ui.getValue(kUiTab, kUiMisc, "Debug") then return end
    if not ui.getValue(kUiTab, kUiMisc, "Active Recoil Line") then return end

    local w, h = ScreenSize.w, ScreenSize.h
    if w == 0 then updateScreenSize(); w = ScreenSize.w; h = ScreenSize.h end
    local cx, cy = w / 2, h / 2

    if not isFiring or not DebugState.SprayPath or #DebugState.SprayPath == 0 then
        draw.CircleFilled(cx, cy, 2, Color3.new(0, 1, 0), 8, 255)
        return
    end

    local path = DebugState.SprayPath
    local maxVisualDist = 100 
    local maxRealDist = 1
    
    for i = 1, #path do
        local d = math.sqrt(path[i].x^2 + path[i].y^2)
        if d > maxRealDist then maxRealDist = d end
    end

    local scale = 1.0
    if maxRealDist > maxVisualDist then
        scale = maxVisualDist / maxRealDist
    end

    if #path > 1 then
        for i = 1, #path - 1 do
            local p1, p2 = path[i], path[i+1]
            draw.Line(cx + (p1.x * scale), cy + (p1.y * scale), cx + (p2.x * scale), cy + (p2.y * scale), Color3.new(0, 1, 0), 2, 200)
        end
    end
    
    local lastP = path[#path]
    draw.CircleFilled(cx + (lastP.x * scale), cy + (lastP.y * scale), 3, Color3.new(0, 1, 0), 8, 255)
end

