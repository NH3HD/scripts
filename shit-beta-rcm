local function IsMappedKeyPressed(dropIndex)
    local name = KeyNames[dropIndex + 1]
    if not name or name == "None" then return false end
    local code = KeyMap[name]
    if not code then return false end
    return keyboard.IsPressed(code)
end

local function GetDistanceToBox(cx, cy, x, y, w, h)
    local closestX = math.max(x, math.min(cx, x + w))
    local closestY = math.max(y, math.min(cy, y + h))
    return math.sqrt((closestX - cx)^2 + (closestY - cy)^2)
end

local function GetTargetInFOV(radius)
    local w, h = ScreenSize.w, ScreenSize.h
    if w == 0 then updateScreenSize(); w = ScreenSize.w; h = ScreenSize.h end
    local cx, cy = w/2, h/2
    
    local closestDist = radius
    local bestTargetName = nil
    local found = false
    
    local success, enemies = pcall(function() return entity.GetPlayers(true) end)
    if success and enemies then
        for _, player in ipairs(enemies) do
            if player.IsAlive and player.IsVisible then
                local bbox = player.BoundingBox
                if bbox then
                    local dist = GetDistanceToBox(cx, cy, bbox.x, bbox.y, bbox.w, bbox.h)
                    if dist <= closestDist then
                        closestDist = dist
                        bestTargetName = player.Name
                        found = true
                    end
                end
            end
        end
    end

    return found, bestTargetName
end

local function GetMagnetTargetPosition(radius)
    local w, h = ScreenSize.w, ScreenSize.h
    if w == 0 then updateScreenSize(); w = ScreenSize.w; h = ScreenSize.h end
    local cx, cy = w/2, h/2
    
    local closestDist = radius
    local bestX, bestY = nil, nil
    
    local success, enemies = pcall(function() return entity.GetPlayers(true) end)
    if success and enemies then
        local aimPart = ui.getValue(kUiTab, kUiMagnet, "Aim Part") or 0
        
        for _, player in ipairs(enemies) do
            if player.IsAlive and player.IsVisible then
                local bbox = player.BoundingBox
                if bbox then
                    local targetX = bbox.x + (bbox.w / 2)
                    local targetY = bbox.y + (bbox.h / 2)
                    
                    if aimPart == 0 then
                        targetY = bbox.y + (bbox.h * 0.1)
                    elseif aimPart == 1 then
                        targetY = bbox.y + (bbox.h * 0.25)
                    end
                    
                    local dist = math.sqrt((targetX - cx)^2 + (targetY - cy)^2)
                    if dist <= closestDist then
                        closestDist = dist
                        bestX, bestY = targetX, targetY
                    end
                end
            end
        end
    end
    
    return bestX, bestY
end

local function UpdateLocalCache()
    local s1, idx = pcall(entity.GetLocalPlayer)
    if s1 and idx then GlobalCache.LocalPlayerIndex = idx end
    
    local s2, lp = pcall(function() return game.LocalPlayer end)
    if s2 and lp then
        local s3, char = pcall(function() return lp.Character end)
        if s3 and char and char.Parent then
            GlobalCache.LocalCharacter = char
        else
            GlobalCache.LocalCharacter = nil
        end
    else
        print("[UniversalRC] Error: Could not access game.LocalPlayer to cache character.")
    end
end

local function CheckActiveTool()
    UpdateLocalCache()
    
    local s1, lp_ent = pcall(function() return entity.get_local_player() end)
    if s1 and type(lp_ent) == "table" and lp_ent.Weapon then
        local wpn = lp_ent.Weapon
        if wpn ~= "" and wpn ~= "None" then
            return true, wpn
        end
    end

    if GlobalCache.LocalCharacter then
        local s2, tool = pcall(function() return GlobalCache.LocalCharacter:FindFirstChildOfClass("Tool") end)
        if s2 and tool then
            return true, tool.Name
        end
    end
    
    return false, "None"
end

