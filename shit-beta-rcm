local function UpdateConfigNames()
    for k in pairs(ConfigNames) do ConfigNames[k] = nil end
    local tempNames = {}
    for name, _ in pairs(AllConfigs) do table.insert(tempNames, name) end
    table.sort(tempNames)
    for _, name in ipairs(tempNames) do table.insert(ConfigNames, name) end
    if #ConfigNames == 0 then table.insert(ConfigNames, "None") end
    
    pcall(function() 
        local currentName = ui.getValue(kUiTab, kUiMisc, "Config Name")
        local foundIdx = 0
        for i, n in ipairs(ConfigNames) do if n == currentName then foundIdx = i - 1; break end end
        ui.setValue(kUiTab, kUiMisc, "Select Config", foundIdx) 
    end)
end

