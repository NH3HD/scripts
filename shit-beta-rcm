local function GetCurrentRecoil(elapsedTime)
    local rXBase = ui.getValue(kUiTab, kUiMain, "Recoil X (Base)") or 0
    local rYBase = ui.getValue(kUiTab, kUiMain, "Recoil Y") or 0

    if not ui.getValue(kUiTabKF, kUiKFMain, "Enable Keyframing") then
        return rXBase, rYBase
    end

    local activeKFs = ui.getValue(kUiTabKF, kUiKFMain, "Active Keyframes") or 3
    local scaleX = (ui.getValue(kUiTabKF, kUiKFMain, "Master Scale X (%)") or 100) / 100.0
    local scaleY = (ui.getValue(kUiTabKF, kUiKFMain, "Master Scale Y (%)") or 100) / 100.0
    
    local pts = {
        { t = 0, x = rXBase, y = rYBase, interp = 0, tension = 2.0 }
    }
    
    local lastT = 0
    for i = 1, activeKFs do
        local kf_t = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Time (ms)") or 0
        local kf_x = (ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil X") or 0) * scaleX
        local kf_y = (ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Recoil Y") or 0) * scaleY
        local kf_interp = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Curve Type") or 0
        local kf_tensionRaw = ui.getValue(kUiTabKF, kUiKFPoints, "KF"..i.." Tension") or 20
        
        kf_t = math.max(lastT + 1, kf_t)
        table.insert(pts, { t = kf_t, x = kf_x, y = kf_y, interp = kf_interp, tension = kf_tensionRaw / 10.0 })
        lastT = kf_t
    end

    for i = 1, #pts - 1 do
        local p1 = pts[i]
        local p2 = pts[i+1]
        
        if elapsedTime >= p1.t and elapsedTime <= p2.t then
            local range = p2.t - p1.t
            if range <= 0 then return p2.x, p2.y end
            
            local alpha = (elapsedTime - p1.t) / range
            -- A curva de como a animação CHEGA no ponto P2 é controlada pelas definições de P2
            alpha = GetKeyframeAlpha(alpha, p2.interp, p2.tension)
            
            local curX = p1.x + (p2.x - p1.x) * alpha
            local curY = p1.y + (p2.y - p1.y) * alpha
            
            return curX, curY
        end
    end

    local lastPt = pts[#pts]
    return lastPt.x, lastPt.y
end

