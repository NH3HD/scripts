local ui_elems = {}

local function addUI(type, name, ...)
    local id
    if type == "Checkbox" then id = ui.NewCheckbox("Visuals", "Visuals Continued", name)
    elseif type == "Dropdown" then id = ui.NewDropdown("Visuals", "Visuals Continued", name, ...)
    elseif type == "SliderInt" then id = ui.NewSliderInt("Visuals", "Visuals Continued", name, ...)
    elseif type == "InputText" then id = ui.NewInputText("Visuals", "Visuals Continued", name)
    end
    table.insert(ui_elems, {name=name, id=id})
end

local function addColor(name)
    local id
    if type(ui.NewColorEdit) == "function" then
        local ok, ret = pcall(ui.NewColorEdit, "Visuals", "Visuals Continued", name)
        if ok then id = ret end
    end
    table.insert(ui_elems, {name=name, id=id})
end

