-- Map Microsoft keys to internal key names
local m_p = {
    esc="Escape", escape="Escape", lctrl="Ctrl", rctrl="Ctrl", ctrl="Ctrl", control="Ctrl",
    lshift="Shift", rshift="Shift", shift="Shift", alt="Alt", lalt="Alt", ralt="Alt", altgr="Alt",
    space="Space", enter="Enter", ["return"]="Enter"
}

-- Keybind string parser and evaluator
local function check_bind(str)
    if type(str) ~= "string" or str == "" then return false end
    str = string.gsub(str, "%s+", "")
    if str == "" then return false end
    str = string.lower(str)
    
    local parts = {}
    for pt in string.gmatch(str, "([^%+]+)") do
        parts[#parts + 1] = pt
    end
    
    if #parts == 0 then return false end
    
    for i = 1, #parts do
        local k = parts[i]
        k = m_p[k] or k
        local ok, res = pcall(keyboard.IsPressed, k)
        if not ok or not res then return false end
    end
    return true
end

-- Main variables
local last_tick = 0
local last_key_state = false
local game_radar_active = true

-- Core Update Loop (Extracts data and sends to Python via JSON file)
cheat.Register("onUpdate", function()
    local c_v = ui.GetValue("Visuals", "Visuals Continued", "Show In-Game Radar")
    local mode = ui.GetValue("Visuals", "Visuals Continued", "Keybind Mode")
    local bind_str = ui.GetValue("Visuals", "Visuals Continued", "Radar Keybind")
    
    local is_pressed = check_bind(bind_str)
    
    -- Handle Toggle Mode
    if mode == 2 then
        if is_pressed and not last_key_state then
            c_v = not c_v
            ui.SetValue("Visuals", "Visuals Continued", "Show In-Game Radar", c_v)
        end
    end
    last_key_state = is_pressed
    
    -- Handle visibility based on modes
    if mode == 3 then
        game_radar_active = c_v
    elseif mode == 1 then
        game_radar_active = c_v and is_pressed
    elseif mode == 2 then
        game_radar_active = c_v
    end

    local now = utility.GetTickCount()
    if now - last_tick < 25 then return end
    last_tick = now
    
    local lp = entity.GetLocalPlayer()
    if not lp or not lp.IsAlive then return end
    
    local root = lp:GetBonePosition("HumanoidRootPart")
    if not root then return end
    
    local target = entity.GetTarget()
    local target_id = (target and target.IsAlive) and target.UserId or -1
    
    local json_out = '{"v":true,"p":['
    local players = entity.GetPlayers()
    local count = 0
    
    for i = 1, #players do
        local p = players[i]
        if p.IsAlive then
            local p_root = p:GetBonePosition("HumanoidRootPart")
            if p_root and p_root.Magnitude > 0 then
                local dx = p_root.X - root.X
                local dz = p_root.Z - root.Z
                local clean_name = string.gsub(p.Name or "", '["\\]', '')
                local is_wl = p.IsWhitelisted and "true" or "false"
                local is_target = (p.UserId == target_id) and "true" or "false"
                
                local rot = p:GetBoneRotation("Head")
                local yaw = 0
                if type(rot) == "table" and rot[9] and rot[3] then
                    yaw = math.atan2(-rot[9], -rot[3])
                end
                
                if count > 0 then json_out = json_out .. "," end
                json_out = json_out .. string.format('{"id":%d,"n":"%s","x":%.1f,"z":%.1f,"hp":%d,"mhp":%d,"w":%s,"t":%s,"y":%.3f}', p.UserId or 0, clean_name, dx, dz, p.Health or 100, p.MaxHealth or 100, is_wl, is_target, yaw)
                count = count + 1
            end
        end
    end
    json_out = json_out .. "]}"
    
    file.write("radar_data.json", json_out)
end)

-- In-Game Visual Overlay Rendering
cheat.Register("onPaint", function()
    if not game_radar_active then return end
    
    local lp = entity.GetLocalPlayer()
    if not lp or not lp.IsAlive then return end
    
    local pos = lp:GetBonePosition("HumanoidRootPart")
    if not pos then return end
    
    local cam = game.GetService("Workspace"):FindFirstChildOfClass("Camera")
    local lv = (cam and cam.CFrame) and cam.CFrame.LookVector or Vector3.new(0,0,-1)
    local yaw = math.atan2(-lv.X, -lv.Z)
    
    local w_s, h_s = draw.GetScreenSize()
    local style = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Style") or 1
    local r_size = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Size") or 200
    local scale = (ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Zoom") or 50) / 50.0
    
    local rx, ry = 20, (h_s / 2) - (r_size / 2)
    local h_size = r_size / 2
    local cx, cy = rx + h_size, ry + h_size
    
    -- Draw Background
    if style == 1 then
        draw.RectFilled(rx, ry, r_size, r_size, Color3.new(0.08, 0.08, 0.09), 4, 0.8)
        draw.Rect(rx, ry, r_size, r_size, Color3.new(0.3, 0.9, 0.8), 1, 4, 1)
        draw.Line(cx, ry, cx, ry + r_size, Color3.new(0.2, 0.2, 0.2), 1, 0.6)
        draw.Line(rx, cy, rx + r_size, cy, Color3.new(0.2, 0.2, 0.2), 1, 0.6)
    elseif style == 2 then
        draw.CircleFilled(cx, cy, h_size, Color3.new(0.08, 0.08, 0.09), 32, 0.8)
        draw.Circle(cx, cy, h_size, Color3.new(0.3, 0.9, 0.8), 32, 1)
        draw.Line(cx, ry - h_size, cx, ry + r_size - h_size, Color3.new(0.2, 0.2, 0.2), 1, 0.6)
        draw.Line(rx, cy, rx + r_size, cy, Color3.new(0.2, 0.2, 0.2), 1, 0.6)
    end
    
    -- Draw Local Player
    draw.CircleFilled(cx, cy, 3, Color3.new(0.4, 0.98, 0.94), 12, 1)
    
    local plyrs = entity.GetPlayers()
    for i = 1, #plyrs do
        local p = plyrs[i]
        if p.IsAlive and p ~= lp then
            local b = p:GetBonePosition("HumanoidRootPart")
            if b and b.Magnitude > 0 then
                local dx, dz = b.X - pos.X, b.Z - pos.Z
                local sn, cs = math.sin(yaw), math.cos(yaw)
                local px = cx + ((dx * cs - dz * sn) * scale)
                local py = cy + ((dx * sn + dz * cs) * scale)
                
                local draw_it = false
                if style == 1 or style == 3 then
                    if px >= rx and px <= rx + r_size and py >= ry and py <= ry + r_size then
                        draw_it = true
                    end
                elseif style == 2 then
                    local dist = math.sqrt((px - cx)^2 + (py - cy)^2)
                    if dist <= h_size then
                        draw_it = true
                    else
                        local ang = math.atan2(py - cy, px - cx)
                        px = cx + math.cos(ang) * h_size
                        py = cy + math.sin(ang) * h_size
                        draw_it = true
                    end
                end
                
                if draw_it then
                    local col = Color3.new(1, 0.2, 0.2)
                    if p.IsWhitelisted then
                        col = Color3.new(0.2, 1, 0.8)
                    elseif not p.IsEnemy then
                        col = Color3.new(1, 1, 0.2)
                    end
                    draw.CircleFilled(px, py, 3, col, 12, 1)
                end
            end
        end
    end
end)
