local function updateUIVisibility(state)
    if type(ui.SetVisible) == "function" then
        for i=1, #ui_elems do
            local e = ui_elems[i]
            local ok = false
            if e.id then
                ok = pcall(ui.SetVisible, e.id, state)
            end
            if not ok then
                pcall(ui.SetVisible, "Visuals", "Visuals Continued", e.name, state)
            end
        end
    end
end

local m_p = {
    esc="Escape", escape="Escape", lctrl="Ctrl", rctrl="Ctrl", ctrl="Ctrl", control="Ctrl",
    lshift="Shift", rshift="Shift", shift="Shift", alt="Alt", lalt="Alt", ralt="Alt", altgr="Alt",
    space="Space", enter="Enter", ["return"]="Enter"
}

local function c_b(str)
    if type(str) ~= "string" or str == "" then return false end
    str = string.gsub(str, "%s+", "")
    if str == "" then return false end
    str = string.lower(str)
    local p = {}
    for pt in string.gmatch(str, "([^%+]+)") do
        p[#p + 1] = pt
    end
    if #p == 0 then return false end
    for i = 1, #p do
        local k = p[i]
        k = m_p[k] or k
        local ok, r = pcall(keyboard.IsPressed, k)
        if not ok or not r then return false end
    end
    return true
end

local l = 0
local l_k = false
local g_ra = true
local i_t = true
local last_main_state = nil

cheat.Register("onUpdate", function()
    local c_v = ui.GetValue("Visuals", "Visuals Continued", "Show In-Game Radar")
    if c_v ~= last_main_state then
        last_main_state = c_v
        updateUIVisibility(c_v)
    end
    
    local md = ui.GetValue("Visuals", "Visuals Continued", "Keybind Mode")
    local bnd = ui.GetValue("Visuals", "Visuals Continued", "Radar Keybind")
    
    local bnd_e = (type(bnd) ~= "string" or string.gsub(bnd, "%s+", "") == "")
    local i_p = c_b(bnd)
    
    if md == 1 then
        if i_p and not l_k then
            i_t = not i_t
        end
    end
    l_k = i_p
    
    if not c_v then
        g_ra = false
    else
        if md == 2 or bnd_e then
            g_ra = true
        elseif md == 0 then
            g_ra = i_p
        elseif md == 1 then
            g_ra = i_t
        end
    end

    local n = utility.GetTickCount()
    if n - l < 25 then return end
    l = n
    
    local p = entity.GetLocalPlayer()
    if not p or not p.IsAlive then return end
    
    local r = p:GetBonePosition("HumanoidRootPart")
    if not r then return end
    
    local tg = entity.GetTarget()
    local ti = (tg and tg.IsAlive) and tg.UserId or -1
    
    local o = '{"v":true,"p":['
    local e = entity.GetPlayers()
    local c = 0
    
    for i = 1, #e do
        local t = e[i]
        if t.IsAlive then
            local b = t:GetBonePosition("HumanoidRootPart")
            if b and b.Magnitude > 0 then
                local x = b.X - r.X
                local z = b.Z - r.Z
                local nm = string.gsub(t.Name or "", '["\\]', '')
                local w = t.IsWhitelisted and "true" or "false"
                local is_t = (t.UserId == ti) and "true" or "false"
                
                local rot = t:GetBoneRotation("Head")
                local y = 0
                if type(rot) == "table" and rot[9] and rot[3] then
                    y = math.atan2(-rot[9], -rot[3])
                end
                
                if c > 0 then o = o .. "," end
                o = o .. string.format('{"id":%d,"n":"%s","x":%.1f,"z":%.1f,"hp":%d,"mhp":%d,"w":%s,"t":%s,"y":%.3f}', t.UserId or 0, nm, x, z, t.Health or 100, t.MaxHealth or 100, w, is_t, y)
                c = c + 1
            end
        end
    end
    o = o .. "]}"
    
    file.write("radar_data.json", o)
end)

local function getC(name, def)
    if type(ui.GetColorEdit) == "function" then
        local ok, r, g, b = pcall(ui.GetColorEdit, "Visuals", "Visuals Continued", name)
        if ok and r and g and b then
            return (r > 1 or g > 1 or b > 1) and Color3.new(r/255, g/255, b/255) or Color3.new(r, g, b)
        end
    end
    return def
end

cheat.Register("onPaint", function()
    if not g_ra then return end
    
    local lp = entity.GetLocalPlayer()
    if not lp or not lp.IsAlive then return end
    
    local pos = lp:GetBonePosition("HumanoidRootPart")
    if not pos then return end
    
    local cam = game.GetService("Workspace"):FindFirstChildOfClass("Camera")
    local lv = cam and cam.LookVector or Vector3.new(0,0,-1)
    local yaw = math.atan2(-lv.X, -lv.Z)
    
    local sty = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Style") or 1
    local rot_cam = ui.GetValue("Visuals", "Visuals Continued", "Rotate with Camera")
    local rsz = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Size") or 200
    local sc = (ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Zoom") or 50) / 50.0
    local rx = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Pos X") or 20
    local ry = ui.GetValue("Visuals", "Visuals Continued", "In-Game Radar Pos Y") or 300
    
    local s_cr = ui.GetValue("Visuals", "Visuals Continued", "Show Crosshair Lines")
    local c_dt = ui.GetValue("Visuals", "Visuals Continued", "Show Out of Field")
    local s_cp = ui.GetValue("Visuals", "Visuals Continued", "Show Compass")
    
    local c_bg = getC("Radar Background Color", Color3.new(0.08, 0.08, 0.09))
    local c_border = getC("Radar Border Color", Color3.new(0.3, 0.9, 0.8))
    local c_enemy = getC("Radar Enemy Color", Color3.new(1, 0.2, 0.2))
    local c_ally = getC("Radar Ally Color", Color3.new(1, 1, 0.2))
    local c_wl = getC("Radar Whitelist Color", Color3.new(0.2, 1, 0.8))
    local c_focus = getC("Radar Focused Target Color", Color3.new(1, 0.2, 1))
    
    local hsz = rsz / 2
    local cx, cy = rx + hsz, ry + hsz
    local sn, cs = math.sin(yaw), math.cos(yaw)
    
    if sty == 0 then
        draw.RectFilled(rx, ry, rsz, rsz, c_bg)
        draw.Rect(rx, ry, rsz, rsz, c_border)
        if s_cr then
            draw.Line(cx, ry, cx, ry + rsz, Color3.new(0.3, 0.3, 0.3))
            draw.Line(rx, cy, rx + rsz, cy, Color3.new(0.3, 0.3, 0.3))
        end
    elseif sty == 1 then
        draw.CircleFilled(cx, cy, hsz, c_bg, 64)
        local segs = 64
        local p_x, p_y = cx + hsz, cy
        for j = 1, segs do
            local ang = (j / segs) * math.pi * 2
            local n_x = cx + math.cos(ang) * hsz
            local n_y = cy + math.sin(ang) * hsz
            draw.Line(p_x, p_y, n_x, n_y, c_border)
            p_x, p_y = n_x, n_y
        end
        if s_cr then
            draw.Line(cx, ry, cx, ry + rsz, Color3.new(0.3, 0.3, 0.3))
            draw.Line(rx, cy, rx + rsz, cy, Color3.new(0.3, 0.3, 0.3))
        end
    elseif sty == 2 then
        if s_cr then
            draw.Line(cx, ry, cx, ry + rsz, Color3.new(0.3, 0.3, 0.3))
            draw.Line(rx, cy, rx + rsz, cy, Color3.new(0.3, 0.3, 0.3))
        end
    end
    
    draw.CircleFilled(cx, cy, 3, Color3.new(0.4, 0.98, 0.94), 12)
    
    if rot_cam then
        draw.Line(cx, cy, cx - 6, cy - 12, Color3.new(0.4, 0.98, 0.94))
        draw.Line(cx, cy, cx + 6, cy - 12, Color3.new(0.4, 0.98, 0.94))
        draw.Line(cx, cy, cx, cy - 12, Color3.new(0.4, 0.98, 0.94))
    else
        local scr_a = math.atan2(lv.Z, lv.X)
        local tx = cx + math.cos(scr_a)*12
        local ty = cy + math.sin(scr_a)*12
        local w1x = cx + math.cos(scr_a - 0.4)*6
        local w1y = cy + math.sin(scr_a - 0.4)*6
        local w2x = cx + math.cos(scr_a + 0.4)*6
        local w2y = cy + math.sin(scr_a + 0.4)*6
        draw.Line(cx, cy, tx, ty, Color3.new(0.4, 0.98, 0.94))
        draw.Line(tx, ty, w1x, w1y, Color3.new(0.4, 0.98, 0.94))
        draw.Line(tx, ty, w2x, w2y, Color3.new(0.4, 0.98, 0.94))
    end
    
    if s_cp and sty ~= 2 then
        local dirs = {
            {n="N", a=-math.pi/2}, {n="NE", a=-math.pi/4}, {n="E", a=0}, {n="SE", a=math.pi/4},
            {n="S", a=math.pi/2}, {n="SW", a=3*math.pi/4}, {n="W", a=math.pi}, {n="NW", a=-3*math.pi/4}
        }
        for i=1, #dirs do
            local d = dirs[i]
            local scr_a = d.a
            if rot_cam then scr_a = d.a + yaw end
            
            local c_dist
            if sty == 0 then
                local mx = math.max(math.abs(math.cos(scr_a)), math.abs(math.sin(scr_a)))
                c_dist = (hsz / mx) + 12
            else
                c_dist = hsz + 12
            end
            
            local px = cx + math.cos(scr_a) * c_dist
            local py = cy + math.sin(scr_a) * c_dist
            
            local ok = pcall(draw.Text, px - 6, py - 6, d.n, Color3.new(0.8, 0.8, 0.8), 12)
            if not ok then pcall(draw.Text, px - 6, py - 6, d.n) end
        end
    end
    
    local act_tg = entity.GetTarget()
    local act_ti = (act_tg and act_tg.IsAlive) and act_tg.UserId or -1

    local plyrs = entity.GetPlayers()
    for i = 1, #plyrs do
        local p = plyrs[i]
        if p.IsAlive and p ~= lp then
            local b = p:GetBonePosition("HumanoidRootPart")
            if b and b.Magnitude > 0 then
                local dx, dz = b.X - pos.X, b.Z - pos.Z
                local dr_x, dr_z = dx, dz
                
                if rot_cam then
                    dr_x = dx * cs - dz * sn
                    dr_z = dx * sn + dz * cs
                end
                
                local px = cx + (dr_x * sc)
                local py = cy + (dr_z * sc)
                
                local draw_it = false
                if sty == 0 or sty == 2 then
                    if px >= rx and px <= rx + rsz and py >= ry and py <= ry + rsz then
                        draw_it = true
                    elseif c_dt then
                        px = math.max(rx, math.min(rx + rsz, px))
                        py = math.max(ry, math.min(ry + rsz, py))
                        draw_it = true
                    end
                elseif sty == 1 then
                    local dist = math.sqrt((px - cx)^2 + (py - cy)^2)
                    if dist <= hsz then
                        draw_it = true
                    elseif c_dt then
                        local ang = math.atan2(py - cy, px - cx)
                        px = cx + math.cos(ang) * hsz
                        py = cy + math.sin(ang) * hsz
                        draw_it = true
                    end
                end
                
                if draw_it then
                    local col = c_enemy
                    if p.UserId == act_ti then
                        col = c_focus
                    elseif p.IsWhitelisted then
                        col = c_wl
                    elseif not p.IsEnemy then
                        col = c_ally
                    end
                    draw.CircleFilled(px, py, 3, col, 12)
                end
            end
        end
    end
end)
